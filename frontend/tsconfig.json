{
	"files": [],
	"references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@/app": ["./src/app/*"],
			"@/entities": ["./src/entities/*"],
			"@/features": ["./src/features/*"],
			"@/pages": ["./src/pages/*"],
			"@/shared": ["./src/shared/*"],
			"@/widgets": ["./src/widgets/*"]
		},
		"experimentalDecorators": true, // ОБЯЗАТЕЛЬНО для @inject
		"emitDecoratorMetadata": true, // ОБЯЗАТЕЛЬНО для DI
		"erasableSyntaxOnly": false // Отключаем, чтобы конструктор работал
	}
}
